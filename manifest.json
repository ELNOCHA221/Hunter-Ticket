{
  "manifest_version": 3,
  "name": "Hunter Ticket",
  "version": "2.0.1",
  "description": "Hunter Ticket - Reclama automáticamente tickets de Discord y envía mensajes de respuesta automática | by BOTX",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://discord.com/*",
    "https://canary.discord.com/*",
    "https://ptb.discord.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://discord.com/app*",
        "https://discord.com/channels/*",
        "https://canary.discord.com/app*",
        "https://canary.discord.com/channels/*",
        "https://ptb.discord.com/app*",
        "https://ptb.discord.com/channels/*"
      ],
      "js": [
        "intercept.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://discord.com/app*",
        "https://discord.com/channels/*",
        "https://canary.discord.com/app*",
        "https://canary.discord.com/channels/*",
        "https://ptb.discord.com/app*",
        "https://ptb.discord.com/channels/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content-overlay.css"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}